{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sorane.dev/profile/sorane-okf/0.3",
  "title": "sorane-okf/0.3",
  "description": "OKF v0.1 profile for sorane SSG: extended types, open-data metadata, AI disclosure.",
  "oneOf": [
    { "$ref": "#/$defs/article" },
    { "$ref": "#/$defs/index" },
    { "$ref": "#/$defs/dataset" },
    { "$ref": "#/$defs/reference" },
    { "$ref": "#/$defs/glossary" },
    { "$ref": "#/$defs/faq" }
  ],
  "$defs": {
    "publisher": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "distribution": {
      "type": "object",
      "required": ["title", "format", "accessURL"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "minLength": 1 },
        "accessURL": { "type": "string", "minLength": 1 },
        "downloadURL": { "type": "string", "minLength": 1 },
        "byteSize": { "type": "integer", "minimum": 0 },
        "checksum": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "temporal": {
      "type": "object",
      "properties": {
        "start": { "type": "string", "minLength": 1 },
        "end": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "okfBase": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "resource": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "profile": { "type": "string" },
        "identifier": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 2 },
        "license": { "type": "string", "minLength": 1 },
        "publisher": { "$ref": "#/$defs/publisher" },
        "theme": { "type": "string", "minLength": 1 },
        "temporal": { "$ref": "#/$defs/temporal" },
        "spatial": { "type": "string", "minLength": 1 },
        "distributions": {
          "type": "array",
          "items": { "$ref": "#/$defs/distribution" }
        },
        "creativeWorkType": {
          "type": "string",
          "enum": ["BlogPosting", "TechArticle"]
        },
        "digitalSourceType": {
          "type": "string",
          "minLength": 1
        },
        "euAiLabel": {
          "type": "string",
          "enum": ["basic", "fully-generated", "partially-modified"]
        },
        "aiDisclosureNote": { "type": "string", "maxLength": 500 },
        "aiSystems": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string" },
              "provider": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "article": {
      "allOf": [
        { "$ref": "#/$defs/okfBase" },
        {
          "properties": { "type": { "const": "article" } },
          "required": ["type", "title"]
        }
      ]
    },
    "index": {
      "allOf": [
        { "$ref": "#/$defs/okfBase" },
        {
          "properties": { "type": { "const": "index" } },
          "required": ["type", "title"]
        }
      ]
    },
    "dataset": {
      "allOf": [
        { "$ref": "#/$defs/okfBase" },
        {
          "properties": {
            "type": { "const": "dataset" },
            "distributions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/distribution" }
            }
          },
          "required": [
            "type",
            "title",
            "description",
            "resource",
            "license",
            "publisher",
            "distributions"
          ]
        }
      ]
    },
    "reference": {
      "allOf": [
        { "$ref": "#/$defs/okfBase" },
        {
          "properties": { "type": { "const": "reference" } },
          "required": ["type", "title"]
        }
      ]
    },
    "glossary": {
      "allOf": [
        { "$ref": "#/$defs/okfBase" },
        {
          "properties": { "type": { "const": "glossary" } },
          "required": ["type", "title"]
        }
      ]
    },
    "faq": {
      "allOf": [
        { "$ref": "#/$defs/okfBase" },
        {
          "properties": { "type": { "const": "faq" } },
          "required": ["type", "title"]
        }
      ]
    }
  }
}
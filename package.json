{
  "name": "sorane",
  "version": "0.4.0",
  "description": "OKF-native static site generator (Rust/TypeScript)",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masanork/sorane.git"
  },
  "homepage": "https://ssg.sorane.dev",
  "bugs": "https://github.com/masanork/sorane/issues",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "sorane": "packages/cli/src/main.ts"
  },
  "scripts": {
    "build": "node packages/cli/src/main.ts build",
    "validate": "node packages/cli/src/main.ts validate",
    "migrate": "node packages/cli/src/main.ts migrate",
    "index": "node packages/cli/src/main.ts index",
    "search": "node packages/cli/src/main.ts search",
    "fetch-model": "node scripts/fetch-model.ts",
    "test": "node --test \"tests/**/*.test.ts\"",
    "test:coverage": "node --experimental-test-coverage --test-isolation=none --test-coverage-lines=90 --test-coverage-branches=65 --test-coverage-functions=60 --test-coverage-include='packages/**/*.ts' --test-coverage-exclude='packages/**/wasm/**' --test-coverage-exclude='packages/search/**' --test-coverage-exclude='packages/cli/src/watch.ts' --test 'tests/**/*.test.ts'",
    "test:coverage:lcov": "c8 --include='packages/**' --exclude='packages/**/wasm/**' --exclude='packages/search/**' --reporter=text-summary --reporter=lcov --report-dir=coverage node --test 'tests/**/*.test.ts'",
    "test:e2e": "playwright test",
    "test:mermaid-build": "node --test tests/mermaid-build.test.ts tests/build-mermaid-build.test.ts",
    "test:c2pa": "node --test tests/c2pa-pass.test.ts tests/static-assets.test.ts tests/asset-provenance.test.ts",
    "test:image-metadata": "node --test tests/iptc-xmp-pass.test.ts tests/static-assets.test.ts tests/asset-provenance.test.ts",
    "typecheck": "tsc --noEmit",
    "cbom-check": "node scripts/cbom-check.ts",
    "supply-chain:status": "node scripts/supply-chain-status.ts",
    "stats": "node scripts/project-stats.ts",
    "stats:json": "node scripts/project-stats.ts --json",
    "stats:history": "node scripts/stats-history.ts",
    "stats:trend": "node scripts/stats-history.ts trend",
    "pack:cli": "npm pack -w @sorane/cli",
    "publish:workspaces": "npm publish -w @sorane/font --access public && npm publish -w @sorane/okf --access public && npm publish -w @sorane/search --access public && npm publish -w @sorane/core --access public && npm publish -w @sorane/cli --access public"
  },
  "engines": {
    "node": ">=23.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "c8": "^10.1.3",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "allowScripts": {
    "better-sqlite3": true,
    "onnxruntime-node": true,
    "protobufjs": true,
    "sharp": true,
    "puppeteer": true,
    "@mermaid-js/mermaid-cli": true
  }
}
